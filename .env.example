# Copiar a .env y llenar con valores reales — .env NUNCA se commitea.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=cambia-esto-por-una-contrasena-fuerte
DB_USERNAME=almacen_app
DB_PASSWORD=cambia-esto-tambien

# --- JWT ---
# Generar una nueva para produccion, por ejemplo con:
#   openssl rand -base64 32
JWT_SECRET=

# --- CORS ---
# Origenes adicionales permitidos ademas del reverse proxy de Nginx
# (normalmente no hace falta tocarlo en produccion — solo aplica si
# algo le pega directo al backend sin pasar por Nginx)
CORS_ALLOWED_ORIGINS=http://localhost:8000

# --- AWS S3 (evidencias fotograficas) ---
AWS_REGION=us-east-2
AWS_S3_BUCKET_EVIDENCIAS=bucket-almacen-secretariado-032401368811-us-east-2-an

# Carpeta logica dentro del bucket. Dejar vacio/sin definir en produccion (usa
# "evidencias" por default). En el ambiente de capacitacion/demo usar un
# prefijo distinto, ej. "evidencias-capacitacion", para no mezclar fotos de
# prueba con las reales.
AWS_S3_PREFIX_EVIDENCIAS=evidencias

# Si la EC2 tiene un IAM role adjunto con permisos al bucket (RECOMENDADO),
# deja estas dos vacias — el SDK toma las credenciales del rol automaticamente.
# Solo llenarlas si NO se usa IAM role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
